<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardColeccion"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    android:clipToOutline="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Imagen de Fondo Compacta (100dp) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivColeccion"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_collection_default"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Badge de Contador Minimalista (Compacto y Seguro) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            app:cardBackgroundColor="#CC000000"
            app:cardCornerRadius="4dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constrainedWidth="true">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvStatsColeccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp"
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="12 items" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Información Inferior (Nombre y Punto de Color) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:background="?attr/colorSurface"
            app:layout_constraintTop_toBottomOf="@id/ivColeccion">

            <!-- Puntito de color minimalista -->
            <View
                android:id="@+id/viewColeccionColor"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="6dp"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_color_dot"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvNombreColeccion" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvNombreColeccion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                app:layout_goneMarginStart="2dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:minLines="2"
                android:includeFontPadding="false"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textSize="12sp"
                android:lineSpacingExtra="1dp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                app:layout_constraintStart_toEndOf="@id/viewColeccionColor"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Nombre de la Colección" />

            <!-- Descripción secundaria compacta -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvDescripcionColeccion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                app:layout_constraintStart_toStartOf="@id/tvNombreColeccion"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvNombreColeccion"
                tools:text="Descripción de la colección..." />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
