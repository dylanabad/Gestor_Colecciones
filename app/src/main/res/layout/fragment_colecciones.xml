<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:padding="16dp">

    <!-- Cabecera: Título y Salir -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvColeccionesTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Colecciones"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnLogout" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Cerrar sesión"
        app:icon="@android:drawable/ic_lock_power_off"
        app:iconTint="?attr/colorError"
        app:layout_constraintTop_toTopOf="@id/tvColeccionesTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvColeccionesTitle"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Buscador (Posición más natural: Arriba) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSearchColecciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:layout_constraintTop_toBottomOf="@id/tvColeccionesTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchColecciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:iconifiedByDefault="false"
            android:queryHint="Buscar colección..."
            android:background="@android:color/transparent"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Acciones Rápidas -->
    <HorizontalScrollView
        android:id="@+id/scrollBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/cardSearchColecciones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingEnd="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBusqueda"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Buscar"
                app:icon="@android:drawable/ic_menu_search" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeseos"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Lista de deseos"
                app:icon="@android:drawable/ic_menu_agenda" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStats"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Estadísticas"
                app:icon="@android:drawable/ic_menu_info_details" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogros"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Logros"
                app:icon="@android:drawable/btn_star" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrestamos"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Préstamos"
                app:icon="@android:drawable/ic_menu_send" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPapelera"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Papelera"
                app:icon="@android:drawable/ic_menu_delete" />

        </LinearLayout>

    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvColecciones"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layoutAnimation="@anim/layout_stagger"
        android:clipToPadding="false"
        android:paddingBottom="96dp"
        app:layout_constraintTop_toBottomOf="@id/scrollBotones"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabExport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:contentDescription="Exportar colecciones"
        android:src="@android:drawable/ic_menu_share"
        app:backgroundTint="?attr/colorSecondaryContainer"
        app:tint="?attr/colorOnSecondaryContainer"
        app:fabSize="mini"
        app:layout_constraintBottom_toTopOf="@id/fabAddColeccion"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddColeccion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:contentDescription="Crear colección"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="?attr/colorPrimary"
        app:tint="?attr/colorOnPrimary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>