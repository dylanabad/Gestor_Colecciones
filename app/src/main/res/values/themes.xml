<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Gestor_Colecciones" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Brand colors -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/on_brand_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_brand_primary_container</item>

        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/on_brand_secondary</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_brand_secondary_container</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/app_background</item>
        <item name="colorSurface">@color/app_surface</item>
        <item name="colorOnSurface">@color/on_app_surface</item>
        <item name="colorSurfaceVariant">@color/app_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_app_surface_variant</item>
        <item name="colorOutline">@color/app_outline</item>

        <!-- System bars -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Dialogs -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Gestor_Colecciones.MaterialAlertDialog</item>
    </style>

    <!-- Theme variants (user-selectable) -->
    <style name="Theme.Gestor_Colecciones.Purple" parent="Theme.Gestor_Colecciones">
        <item name="colorPrimary">@color/theme_purple_primary</item>
        <item name="colorOnPrimary">@color/theme_purple_on_primary</item>
        <item name="colorPrimaryContainer">@color/theme_purple_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/theme_purple_on_primary_container</item>
        <!-- Sincronizamos el secundario para evitar verdes persistentes -->
        <item name="colorSecondary">?attr/colorPrimary</item>
        <item name="colorSecondaryContainer">?attr/colorPrimaryContainer</item>
    </style>

    <style name="Theme.Gestor_Colecciones.Green" parent="Theme.Gestor_Colecciones">
        <item name="colorPrimary">@color/theme_green_primary</item>
        <item name="colorOnPrimary">@color/theme_green_on_primary</item>
        <item name="colorPrimaryContainer">@color/theme_green_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/theme_green_on_primary_container</item>
        <item name="colorSecondary">?attr/colorPrimary</item>
        <item name="colorSecondaryContainer">?attr/colorPrimaryContainer</item>
    </style>

    <style name="Theme.Gestor_Colecciones.Orange" parent="Theme.Gestor_Colecciones">
        <item name="colorPrimary">@color/theme_orange_primary</item>
        <item name="colorOnPrimary">@color/theme_orange_on_primary</item>
        <item name="colorPrimaryContainer">@color/theme_orange_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/theme_orange_on_primary_container</item>
        <item name="colorSecondary">?attr/colorPrimary</item>
        <item name="colorSecondaryContainer">?attr/colorPrimaryContainer</item>
    </style>

    <style name="ThemeOverlay.Gestor_Colecciones.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Gestor_Colecciones.Dialog</item>
    </style>

    <style name="ShapeAppearance.Gestor_Colecciones.Dialog" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

</resources>
