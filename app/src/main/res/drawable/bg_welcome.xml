<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="?attr/colorPrimaryContainer"
                android:endColor="@color/app_background" />
        </shape>
    </item>

    <!-- Soft blobs -->
    <item
        android:left="-80dp"
        android:top="40dp">
        <shape android:shape="oval">
            <size
                android:width="260dp"
                android:height="260dp" />
            <solid android:color="#33FFFFFF" />
        </shape>
    </item>

    <item
        android:right="-90dp"
        android:top="220dp">
        <shape android:shape="oval">
            <size
                android:width="220dp"
                android:height="220dp" />
            <solid android:color="#1F2F6BFF" />
        </shape>
    </item>

    <item
        android:right="-60dp"
        android:bottom="-80dp">
        <shape android:shape="oval">
            <size
                android:width="320dp"
                android:height="320dp" />
            <solid android:color="#1F00A896" />
        </shape>
    </item>
</layer-list>
